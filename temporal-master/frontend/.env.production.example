# ══════════════════════════════════════════════════════════════════════════════
#  DAKI EdTech — Variables de Entorno para VERCEL (Frontend Next.js)
#  Fase 1: Core Deployment | Pegar en: Vercel Dashboard → Settings → Environment Variables
#
#  INSTRUCCIONES:
#    1. En Vercel: Settings → Environment Variables → Add New
#    2. Seleccionar entornos: Production + Preview + Development
#    3. Root Directory del proyecto en Vercel: frontend/
# ══════════════════════════════════════════════════════════════════════════════

# ── Backend (Render) ──────────────────────────────────────────────────────────
# Obtener de: Render Dashboard → tu servicio → Settings → URL pública
# Ejemplo: https://daki-api.onrender.com
NEXT_PUBLIC_API_URL=https://TU-SERVICIO.onrender.com

# ── Pagos — FASE 2 (dejar en blanco por ahora) ───────────────────────────────
# Cuando esté lista la pasarela de pago, habilitar con:
# NEXT_PUBLIC_PAYMENT_ENABLED=true
# NEXT_PUBLIC_PAYMENT_URL=https://pay.dakiedtech.com
NEXT_PUBLIC_PAYMENT_ENABLED=false
NEXT_PUBLIC_PAYMENT_URL=
