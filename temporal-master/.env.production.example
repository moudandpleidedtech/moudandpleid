# ══════════════════════════════════════════════════════════════════════════════
#  DAKI EdTech — Variables de Entorno para RENDER (Backend)
#  Fase 1: Core Deployment | Pegar en: Render Dashboard → Environment
#
#  INSTRUCCIONES:
#    1. Copiá cada variable al panel de Render (Environment → Add Variable)
#    2. NUNCA subas este archivo a Git con valores reales
#    3. Generá los secretos con: python -c "import secrets; print(secrets.token_hex(32))"
# ══════════════════════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=DAKI EdTech
APP_VERSION=0.1.0
DEBUG=False

# ── Base de Datos (Neon) ──────────────────────────────────────────────────────
# Obtener de: Neon Dashboard → Project → Connection String
# Formato asyncpg: reemplazar "postgresql://" por "postgresql+asyncpg://"
# y agregar "?ssl=require" al final
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<ep-xxx>.us-east-2.aws.neon.tech/<dbname>?ssl=require
DB_SSL=True

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REEMPLAZAR_CON_TOKEN_HEX_64_CHARS

# ── IA — Anthropic ────────────────────────────────────────────────────────────
# Obtener de: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR

# ── CORS — Frontend ───────────────────────────────────────────────────────────
# Completar DESPUÉS de hacer el primer deploy en Vercel
# Render necesita saber desde qué dominio le van a hablar
FRONTEND_URL=https://TU-PROYECTO.vercel.app
# Si tenés dominio propio ya apuntado, agregarlo acá también:
# ALLOWED_ORIGINS=["https://dakiedtech.com","https://www.dakiedtech.com","https://TU-PROYECTO.vercel.app"]

# ── Tokens JWT ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# ── Pagos — FASE 2 (dejar en blanco por ahora) ───────────────────────────────
# El webhook no se activará hasta que configures la pasarela real en Fase 2
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
PAYMENT_WEBHOOK_SECRET=REEMPLAZAR_CUANDO_LLEGUE_FASE_2
LICENSE_PRICE_USD=24.90

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Obtener de: console.cloud.google.com → APIs → Credenciales → OAuth 2.0
# GOOGLE_REDIRECT_URI debe coincidir exactamente con la URI registrada en Google Cloud Console
GOOGLE_CLIENT_ID=REEMPLAZAR_CON_CLIENT_ID
GOOGLE_CLIENT_SECRET=REEMPLAZAR_CON_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://TU-SERVICIO.onrender.com/api/v1/auth/google/callback

# ── Alertas CEO (Opcionales en Fase 1) ───────────────────────────────────────
ALERT_DISCORD_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
