# ── PostgreSQL (used by docker-compose db service) ───────────────────────────
POSTGRES_USER=quest_user
POSTGRES_PASSWORD=quest_pass
POSTGRES_DB=pythonquest

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# In Docker: hostname = service name "db" (internal quest_network).
# Outside Docker (local): replace "db" with "localhost".
DATABASE_URL=postgresql+asyncpg://quest_user:quest_pass@db:5432/pythonquest

APP_NAME="DAKI EdTech"
APP_VERSION="0.1.0"
DEBUG=True
SECRET_KEY=change-me-in-production

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Points to the API as seen from the browser (not Docker-internal).
NEXT_PUBLIC_API_URL=http://localhost:8000
